<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sportsmanager.ui.controller.MatchController"
      spacing="24" prefWidth="900" prefHeight="600"
      styleClass="root-pane">
    <padding><Insets top="40" right="50" bottom="40" left="50"/></padding>

    <!-- Header / Scoreboard -->
    <VBox alignment="CENTER" spacing="8" 
          style="-fx-padding: 24;
           -fx-background-color: #1e293b; 
           -fx-background-radius: 10; 
           -fx-border-color: #334155; 
           -fx-border-radius: 10;">
        
        <Label text="MATCH DAY" style="-fx-text-fill: #64748b;
         -fx-font-size: 11px; 
         -fx-font-weight: bold;"/>
        
        <HBox alignment="CENTER" spacing="32">
            <Label fx:id="homeTeamLabel" text="Home" 
                   style="-fx-font-size: 24px; 
                   -fx-font-weight: bold; 
                   -fx-text-fill: #f8fafc;" prefWidth="250" alignment="CENTER_RIGHT"/>
            
            <Label fx:id="scoreLabel" text="0 - 0" 
                   style="-fx-font-size: 48px;
                   -fx-font-weight: bold; 
                   -fx-text-fill: #fbbf24;"/>
            
            <Label fx:id="awayTeamLabel" text="Away" 
                   style="-fx-font-size: 24px; 
                   -fx-font-weight: bold; 
                   -fx-text-fill: #f8fafc;" prefWidth="250" alignment="CENTER_LEFT"/>
        </HBox>

        <Label fx:id="periodLabel" text="Half 0 of 0" 
               style="-fx-font-size: 16px;
               -fx-text-fill: #94a3b8;"/>
        
        <Label fx:id="statusLabel" text="Status" 
               style="-fx-font-size: 14px; 
               -fx-text-fill: #4ade80; 
               -fx-font-weight: bold;"/>
    </VBox>

    <!-- Action buttons row -->
    <HBox spacing="16" alignment="CENTER">
        <Button fx:id="simulateButton" text="Simulate Period" onAction="#onSimulatePeriod" styleClass="primary-button"/>
        
        <VBox fx:id="halftimeOverlay" visible="false" managed="${halftimeOverlay.visible}">
             <Button text="Change Tactics" onAction="#onChangeTactics" styleClass="primary-button" style="-fx-background-color: #f59e0b;"/>
        </VBox>
        
        <Button fx:id="dashboardButton" text="Return to Dashboard" onAction="#onReturnDashboard" styleClass="primary-button" style="-fx-background-color: #3b82f6;" visible="false" managed="${dashboardButton.visible}"/>
    </HBox>

    <!-- Event Log -->
    <VBox spacing="8" VBox.vgrow="ALWAYS"
          style="-fx-padding: 16; 
          -fx-background-color: #1e293b; 
          -fx-background-radius: 10; 
          -fx-border-color: #334155; 
          -fx-border-radius: 10;">
        <Label text="MATCH EVENTS" style="-fx-text-fill: #64748b; 
        -fx-font-size: 11px; 
        -fx-font-weight: bold;"/>
        <ListView fx:id="eventLog" styleClass="list-view" VBox.vgrow="ALWAYS"/>
    </VBox>

</VBox>

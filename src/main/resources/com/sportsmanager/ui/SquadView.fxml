<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.sportsmanager.ui.controller.SquadController"
      spacing="12" prefWidth="960" prefHeight="660"
      styleClass="root-pane">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <!-- Header row -->
    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← Dashboard" onAction="#onBackToDashboard" styleClass="primary-button"/>
        <Label text="Squad Management" styleClass="title-label" style="-fx-font-size: 26px;"/>
    </HBox>

    <!-- Position filter buttons -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Filter:" style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px;"/>
        <Button fx:id="btnAll"  text="All"  onAction="#onFilterAll"/>
        <Button fx:id="btnGK"   text="GK"   onAction="#onFilterGK"/>
        <Button fx:id="btnDEF"  text="DEF"  onAction="#onFilterDEF"/>
        <Button fx:id="btnMID"  text="MID"  onAction="#onFilterMID"/>
        <Button fx:id="btnFWD"  text="FWD"  onAction="#onFilterFWD"/>
    </HBox>

    <!-- Table + detail panel -->
    <HBox spacing="16" VBox.vgrow="ALWAYS">

        <!-- Squad TableView -->
        <TableView fx:id="squadTable" HBox.hgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity" styleClass="list-view">
            <columns>
                <TableColumn fx:id="colName"    text="Name"   prefWidth="220"/>
                <TableColumn fx:id="colPos"     text="Pos"    prefWidth="65"/>
                <TableColumn fx:id="colOvr"     text="OVR"    prefWidth="65"/>
                <TableColumn fx:id="colGoals"   text="Goals"  prefWidth="70"/>
                <TableColumn fx:id="colApps"    text="Apps"   prefWidth="70"/>
                <TableColumn fx:id="colStatus"  text="Status" prefWidth="115"/>
            </columns>
        </TableView>

        <!-- Attribute detail panel -->
        <VBox spacing="7" prefWidth="380" maxHeight="Infinity"
              style="-fx-padding: 14; -fx-background-color: #1e293b; -fx-background-radius: 8; -fx-border-color: #334155; -fx-border-radius: 8;">
            <Label text="Player Details" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
            <Label fx:id="lblPlayerName" text="— Select a player —"
                   style="-fx-font-size: 14px; -fx-text-fill: #94a3b8;"/>
            <Label fx:id="lblPlayerPos"  text="" style="-fx-text-fill: #cbd5e1;"/>
            <Label fx:id="lblPlayerAge"  text="" style="-fx-text-fill: #cbd5e1;"/>
            <Separator style="-fx-background-color: #334155;"/>
            <Label text="Attributes" style="-fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            <Label fx:id="lblSpeed"       text="" style="-fx-text-fill: #e2e8f0;"/>
            <Label fx:id="lblShooting"    text="" style="-fx-text-fill: #e2e8f0;"/>
            <Label fx:id="lblPassing"     text="" style="-fx-text-fill: #e2e8f0;"/>
            <Label fx:id="lblBallControl" text="" style="-fx-text-fill: #e2e8f0;"/>
            <Label fx:id="lblDefending"   text="" style="-fx-text-fill: #e2e8f0;"/>
            <Label fx:id="lblPhysicality" text="" style="-fx-text-fill: #e2e8f0;"/>
            <Separator style="-fx-background-color: #334155;"/>
            <Label text="Season Stats" style="-fx-font-weight: bold; -fx-text-fill: #94a3b8; -fx-font-size: 12px;"/>
            <Label fx:id="lblGoals"       text="" style="-fx-text-fill: #4ade80; -fx-font-weight: bold;"/>
            <Label fx:id="lblYellowCards" text="" style="-fx-text-fill: #facc15;"/>
            <Label fx:id="lblAppearances" text="" style="-fx-text-fill: #e2e8f0;"/>
            <Separator style="-fx-background-color: #334155;"/>
            <Label fx:id="lblInjury" text="" style="-fx-text-fill: #f87171; -fx-font-weight: bold;"/>
        </VBox>

    </HBox>
</VBox>
